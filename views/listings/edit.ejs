<% layout("/layouts/boilerplate") %>

<div class="row justify-content-center mt-4">
  <div class="col-12 col-md-10 col-lg-8">
    <h2 class="mb-3">Edit Your Listing</h2>
    <% if (typeof error !== "undefined" && error) { %>
      <div class="alert alert-danger rounded-4 border-0 shadow-sm" role="alert"><%= error %></div>
    <% } %>
<form
  method="POST"
  action="/listings/<%= listing._id %>?_method=PUT"
  enctype="multipart/form-data"
  class="p-3 p-md-4 rounded-4 border bg-white shadow-sm"
  data-staybee-listing-form
>
  <div class="mb-3">
    <label for="title" class="form-label">Title</label>
    <input
      name="listing[title]"
      value="<%= listing.title %>"
      type="text"
      class="form-control"
    />
  </div>
  <div class="mb-3">
    <label for="description" class="form-label">Description</label>
    <textarea name="listing[description]" class="form-control"><%= listing.description %></textarea>
  </div>

  <div class="mb-3">
    <label class="form-label fw-semibold">Property Type</label>
    <div class="form-text mb-2">Select the type of property you are listing.</div>
    <input type="hidden" name="listing[propertyType]" id="propertyTypeHidden" value="<%= listing.propertyType || '' %>">
    <div class="room-type-chips" id="propertyTypeChips">
      <button type="button" class="room-type-chip-btn" data-value="PG">🛏️ PG</button>
      <button type="button" class="room-type-chip-btn" data-value="Hostel">🏢 Hostel</button>
      <button type="button" class="room-type-chip-btn" data-value="Room">🚪 Room</button>
    </div>
  </div>

  <div class="mb-3">
    <label class="form-label fw-semibold">Room Access Type</label>
    <div class="form-text mb-2">Select how the room is accessed.</div>
    <input type="hidden" name="listing[roomAccessType]" id="roomAccessTypeHidden" value="<%= listing.roomAccessType || '' %>">
    <div class="room-type-chips" id="roomAccessTypeChips">
      <button type="button" class="room-type-chip-btn" data-value="Independent">🔑 Independent</button>
      <button type="button" class="room-type-chip-btn" data-value="Dependent">🔗 Dependent</button>
    </div>
  </div>

  <script>
    (function () {
      function initChips(hiddenId, chipsId) {
        var hidden = document.getElementById(hiddenId);
        var chips = document.getElementById(chipsId);
        if (!hidden || !chips) return;
        function syncVisual() {
          chips.querySelectorAll(".room-type-chip-btn").forEach(function (b) {
            b.classList.toggle("selected", b.getAttribute("data-value") === hidden.value);
          });
        }
        syncVisual();
        chips.querySelectorAll(".room-type-chip-btn").forEach(function (btn) {
          btn.addEventListener("click", function () {
            var val = btn.getAttribute("data-value");
            hidden.value = (hidden.value === val) ? "" : val;
            syncVisual();
          });
        });
        var form = hidden.closest("form");
        if (form) {
          form.addEventListener("submit", function () {
            var sel = chips.querySelector(".room-type-chip-btn.selected");
            hidden.value = sel ? sel.getAttribute("data-value") : hidden.value;
          });
        }
      }
      initChips("propertyTypeHidden", "propertyTypeChips");
      initChips("roomAccessTypeHidden", "roomAccessTypeChips");
    })();
  </script>

  <div class="mb-3">
    <label class="form-label fw-semibold">Facilities &amp; Amenities</label>
    <div class="form-text mb-2">Select all facilities available at this property.</div>
    <input type="hidden" name="listing[facilities]" id="facilitiesHidden" value="<%= (listing.facilities || []).join(',') %>">
    <div class="facilities-form-grid">
      <label class="facility-chip-label"><i class="fa-solid fa-wifi"></i> Wi-Fi</label>
      <label class="facility-chip-label"><i class="fa-solid fa-video"></i> CCTV</label>
      <label class="facility-chip-label"><i class="fa-solid fa-fire-flame-curved"></i> Geyser</label>
      <label class="facility-chip-label"><i class="fa-solid fa-bolt"></i> Inverter</label>
      <label class="facility-chip-label"><i class="fa-solid fa-snowflake"></i> Air Conditioner (AC)</label>
      <label class="facility-chip-label"><i class="fa-solid fa-square-parking"></i> Parking</label>
      <label class="facility-chip-label"><i class="fa-solid fa-soap"></i> Laundry</label>
      <label class="facility-chip-label"><i class="fa-solid fa-faucet"></i> Water Supply</label>
      <label class="facility-chip-label"><i class="fa-solid fa-bath"></i> Attached Bathroom</label>
      <label class="facility-chip-label"><i class="fa-solid fa-utensils"></i> Kitchen Access</label>
      <label class="facility-chip-label"><i class="fa-solid fa-plug"></i> Power Backup</label>
      <label class="facility-chip-label"><i class="fa-solid fa-pen-ruler"></i> Study Table</label>
      <label class="facility-chip-label"><i class="fa-solid fa-shield-halved"></i> Security Guard</label>
    </div>
    <script>
      (function () {
        var hidden = document.getElementById("facilitiesHidden");
        var labels = document.querySelectorAll(".facilities-form-grid .facility-chip-label");
        var saved = hidden.value ? hidden.value.split(",") : [];
        var selected = new Set(saved.map(function (v) { return v.trim(); }));

        labels.forEach(function (label) {
          var name = label.textContent.trim();
          if (selected.has(name)) label.classList.add("facility-selected");
          label.addEventListener("click", function () {
            if (selected.has(name)) {
              selected.delete(name);
              label.classList.remove("facility-selected");
            } else {
              selected.add(name);
              label.classList.add("facility-selected");
            }
            hidden.value = Array.from(selected).join(",");
          });
        });
      })();
    </script>
  </div>

  <div class="mb-3">
    <label class="form-label">Current Images</label>
    <div class="d-flex flex-wrap gap-2" id="currentImagesGrid">
      <% if (listing.images && listing.images.length > 0) { %>
        <% listing.images.forEach(function (img) { %>
          <div class="edit-image-item mb-2" data-image-path="<%= img %>">
            <img
              src="<%= img %>"
              alt="Listing image"
              class="img-fluid"
              style="max-height: 120px; object-fit: cover;"
            />
            <button type="button" class="edit-image-delete-btn" title="Delete image" aria-label="Delete image">
              <i class="fa-solid fa-trash"></i>
            </button>
          </div>
        <% }) %>
      <% } else { %>
        <% if (listing.image) { %>
          <div class="edit-image-item mb-2" data-image-path="<%= listing.image %>">
            <img
              src="<%= listing.image %>"
              alt="Listing image"
              class="img-fluid"
              style="max-height: 120px; object-fit: cover;"
            />
            <button type="button" class="edit-image-delete-btn" title="Delete image" aria-label="Delete image">
              <i class="fa-solid fa-trash"></i>
            </button>
          </div>
        <% } %>
      <% } %>
    </div>
    <div id="noImagesText" class="text-muted small mt-2 d-none">No images left. Upload new images before saving.</div>
  </div>
  <div class="mb-3">
    <label for="images" class="form-label">Upload New Images (optional)</label>
    <input
      type="file"
      id="images"
      name="images"
      class="form-control"
      accept=".jpg,.jpeg,.png,image/jpeg,image/png"
      multiple
    />
    <div class="form-text">
      New images are added to existing ones. Use the delete icon on existing images to remove selected images.
    </div>
  </div>
  <div class="mb-3">
    <label class="form-label fw-semibold">Pricing</label>
    <div class="row g-3">
      <div class="col-sm-6">
        <label class="form-label small text-muted mb-1">Monthly Rent (₹)</label>
        <div class="input-group">
          <span class="input-group-text text-muted">₹</span>
          <input
            name="listing[price]"
            class="form-control"
            value="<%= listing.price || '' %>"
            placeholder="e.g. 12000"
            type="number"
            min="0"
          />
          <span class="input-group-text text-muted small">/ mo</span>
        </div>
      </div>
      <div class="col-sm-6">
        <label class="form-label small text-muted mb-1">
          Yearly Rent (₹)
          <span class="badge bg-success-subtle text-success fw-normal ms-1" style="font-size:0.7rem;">Optional</span>
        </label>
        <div class="input-group">
          <span class="input-group-text text-muted">₹</span>
          <input
            name="listing[priceYearly]"
            class="form-control"
            value="<%= listing.priceYearly || '' %>"
            placeholder="e.g. 120000"
            type="number"
            min="0"
          />
          <span class="input-group-text text-muted small">/ yr</span>
        </div>
        <div class="form-text">Offer a discounted yearly rate to attract long-term tenants.</div>
      </div>
    </div>
  </div>
  <div class="mb-3">
    <label for="country" class="form-label">Country</label>
    <input
      name="listing[country]"
      class="form-control"
      value="<%= listing.country %>"
      type="text"
    />
  </div>
  <div class="mb-3">
    <label for="location" class="form-label">Location (short label)</label>
    <input
      id="location"
      name="listing[location]"
      class="form-control"
      value="<%= listing.location %>"
      type="text"
    />
    <div class="form-text">Shown in listings; use the map for the exact pin.</div>
  </div>

  <%- include('../includes/map-location-picker', {
    hasExistingCoords: listing.latitude != null && listing.longitude != null,
    initialLat: listing.latitude,
    initialLng: listing.longitude,
    initialAddress: listing.locationAddress || '',
    showClearControl: true
  }) %>
  <div class="mb-3">
    <label for="ownerContact" class="form-label">Owner Contact Number</label>
    <input
      id="ownerContact"
      name="listing[ownerContact]"
      class="form-control"
      value="<%= listing.ownerContact || '' %>"
      placeholder="Add contact number"
      type="tel"
    />
  </div>
  <div class="mb-3">
    <label for="whatsappNumber" class="form-label">WhatsApp Number</label>
    <input
      id="whatsappNumber"
      name="listing[whatsappNumber]"
      class="form-control"
      value="<%= listing.whatsappNumber || '' %>"
      placeholder="Add WhatsApp number"
      type="tel"
    />
  </div>
  <div class="mb-3">
    <label for="status" class="form-label">Availability Status</label>
    <select name="listing[status]" id="status" class="form-select">
      <option value="Available" <%= listing.status === 'Available' ? 'selected' : '' %>>Available</option>
      <option value="Booked" <%= listing.status === 'Booked' ? 'selected' : '' %>>Booked</option>
      <option value="Coming Soon" <%= listing.status === 'Coming Soon' ? 'selected' : '' %>>Coming Soon</option>
    </select>
  </div>

  <div class="d-grid mt-3">
    <% if (listing.approvalStatus === 'rejected') { %>
      <button type="submit" class="btn btn-warning btn-lg fw-semibold">Re-submit for Approval</button>
    <% } else { %>
      <button type="submit" class="btn btn-primary btn-lg fw-semibold">Save Changes</button>
    <% } %>
  </div>
</form>
  </div>
</div>

<script>
  (function () {
    var form = document.querySelector('form[action*="/listings/"][action*="_method=PUT"]');
    var grid = document.getElementById("currentImagesGrid");
    var noImagesText = document.getElementById("noImagesText");
    if (!form || !grid) return;

    function syncNoImagesState() {
      var visibleItems = grid.querySelectorAll(".edit-image-item");
      if (noImagesText) {
        noImagesText.classList.toggle("d-none", visibleItems.length > 0);
      }
    }

    grid.addEventListener("click", function (e) {
      var deleteBtn = e.target.closest(".edit-image-delete-btn");
      if (!deleteBtn) return;
      e.preventDefault();

      var imageItem = deleteBtn.closest(".edit-image-item");
      if (!imageItem) return;
      var imagePath = imageItem.getAttribute("data-image-path");
      if (!imagePath) return;

      var hiddenInput = document.createElement("input");
      hiddenInput.type = "hidden";
      hiddenInput.name = "deleteImages";
      hiddenInput.value = imagePath;
      form.appendChild(hiddenInput);

      imageItem.remove();
      syncNoImagesState();
    });

    syncNoImagesState();
  })();
</script>
