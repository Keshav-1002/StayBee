<% layout("/layouts/boilerplate") %>

<div class="d-flex justify-content-between align-items-center mt-3">
  <div>
    <h3 class="mb-0">My Favourites</h3>
    <p class="text-muted mb-0" style="font-size: 0.9rem;">
      Rooms you've saved for later.
    </p>
  </div>
</div>

<% var FAV_PT_EMOJIS = {'PG':'🛏️','Hostel':'🏢','Room':'🚪'}; %>
<% var FAV_RAT_EMOJIS = {'Independent':'🔑','Dependent':'🔗'}; %>
<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3 g-md-4 mt-3" id="favouritesGrid">
  <% if (allListing && allListing.length > 0) { %>
    <% allListing.forEach(function (listing) { %>
      <% var statusText = listing.status || 'Available'; %>
      <% var statusClass = statusText === 'Available' ? 'status-available' : (statusText === 'Booked' ? 'status-booked' : 'status-comingsoon'); %>
      <div class="col" data-favourite-card="<%= listing._id %>">
        <a
          href="/listings/<%= listing._id %>"
          class="listing-link text-decoration-none text-dark"
        >
          <div class="card listing-card h-100 position-relative">
            <span class="badge position-absolute top-0 start-0 m-2 status-badge <%= statusClass %>">
              <%= statusText %>
            </span>
            <form
              action="/listings/<%= listing._id %>/favourite/toggle"
              method="POST"
              class="position-absolute top-0 end-0 m-2 js-favourite-form"
              style="z-index: 5;"
              data-listing-id="<%= listing._id %>"
              data-is-favourite="true"
            >
              <button type="submit" class="btn btn-sm btn-light rounded-circle p-2 shadow-sm js-favourite-btn" onclick="event.stopPropagation();" title="Remove from favourites">
                <i class="fa-solid fa-heart text-danger js-favourite-icon"></i>
              </button>
            </form>
            <div
              id="carousel-fav-<%= listing._id %>"
              class="carousel slide"
              data-bs-ride="carousel"
              data-bs-interval="5000"
            >
              <div class="carousel-inner">
                <% const hasImagesFav = listing.images && listing.images.length > 0; %>
                <% const imgListFav = hasImagesFav ? listing.images : [listing.image]; %>
                <% imgListFav.forEach(function (img, idx) { %>
                  <div class="carousel-item <%= idx === 0 ? 'active' : '' %>">
                    <img
                      src="<%= img %>"
                      class="d-block w-100 img-lightbox-card listing-card-img"
                      alt="listing_image"
                      data-images='<%= JSON.stringify(imgListFav) %>'
                      data-index="<%= idx %>"
                    />
                  </div>
                <% }) %>
              </div>
              <% if (imgListFav.length > 1) { %>
                <button class="carousel-control-prev" type="button" data-bs-target="#carousel-fav-<%= listing._id %>" data-bs-slide="prev" style="width: 12%;">
                  <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                  <span class="visually-hidden">Previous</span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#carousel-fav-<%= listing._id %>" data-bs-slide="next" style="width: 12%;">
                  <span class="carousel-control-next-icon" aria-hidden="true"></span>
                  <span class="visually-hidden">Next</span>
                </button>
              <% } %>
            </div>
            <div class="card-body">
              <p class="card-text mb-1 d-flex align-items-center gap-2 flex-wrap">
                <b><%= listing.title %></b>
                <span class="status-dot <%= statusClass %>" aria-label="<%= statusText %>" title="<%= statusText %>"></span>
              </p>
              <% if (listing.averageRating || listing.rating) { %>
                <% const avgRating = listing.averageRating || listing.rating; %>
                <% const totalReviews = listing.reviewCount || (listing.rating ? 1 : 0); %>
                <p class="card-text mb-1 text-warning small">
                  <span class="text-muted me-1"><%= avgRating %></span>
                  <% for (var i = 1; i <= 5; i++) { %>
                    <i class="fa-<%= i <= Math.round(avgRating) ? 'solid' : 'regular' %> fa-star"></i>
                  <% } %>
                  <span class="text-muted ms-1">(<%= totalReviews %> <%= totalReviews === 1 ? 'review' : 'reviews' %>)</span>
                </p>
              <% } %>
              <div class="price-block">
                <div class="price-block-inner">
                  <div class="price-block-left">
                    <p class="card-text mb-1">
                      <span class="fw-semibold">&#8377; <%= listing.price ? listing.price.toLocaleString("en-IN") : '—' %></span>
                      <span class="text-muted small">/ month</span>
                    </p>
                    <% if (listing.priceYearly != null && listing.priceYearly > 0) { %>
                      <p class="card-text mb-0 mt-1">
                        <span class="price-yearly-pill">
                          <i class="fa-solid fa-tag"></i>
                          &#8377; <%= listing.priceYearly.toLocaleString("en-IN") %> / year &bull; Best Value
                        </span>
                      </p>
                    <% } %>
                  </div>
                  <% if (listing.propertyType || listing.roomAccessType) { %>
                    <div class="room-type-badges-col">
                      <% if (listing.propertyType) { %>
                        <span class="room-type-badge"><%= FAV_PT_EMOJIS[listing.propertyType] || '' %>&nbsp;<%= listing.propertyType %></span>
                      <% } %>
                      <% if (listing.roomAccessType) { %>
                        <span class="room-type-badge room-type-badge-access"><%= FAV_RAT_EMOJIS[listing.roomAccessType] || '' %>&nbsp;<%= listing.roomAccessType %></span>
                      <% } %>
                    </div>
                  <% } %>
                </div>
              </div>
            </div>
          </div>
        </a>
      </div>
    <% }); %>
  <% } else { %>
    <div class="col-12 d-flex justify-content-center align-items-center min-vh-100" id="favouritesEmptyState">
      <div class="text-center py-5 text-muted">
        <i class="fa-regular fa-heart fa-3x mb-3"></i>
        <p class="mb-0">No favourites yet.</p>
        <p class="small">Browse listings and click "Add to favourites" to save rooms you like.</p>
        <a href="/listings" class="btn btn-primary mt-3">Explore Listings</a>
      </div>
    </div>
  <% } %>
</div>

<% if (allListing && allListing.length > 0) { %>
  <div class="col-12 d-none d-flex justify-content-center align-items-center min-vh-100" id="favouritesEmptyState">
    <div class="text-center py-5 text-muted">
      <i class="fa-regular fa-heart fa-3x mb-3"></i>
      <p class="mb-0">No favourites yet.</p>
      <p class="small">Browse listings and click "Add to favourites" to save rooms you like.</p>
      <a href="/listings" class="btn btn-primary mt-3">Explore Listings</a>
    </div>
  </div>
<% } %>

<script>
  (function () {
    var grid = document.getElementById("favouritesGrid");
    var emptyState = document.getElementById("favouritesEmptyState");
    if (!grid) return;

    grid.querySelectorAll(".img-lightbox-card").forEach(function (imgEl) {
      imgEl.addEventListener("click", function (e) {
        e.preventDefault();
        e.stopPropagation();
        var images = JSON.parse(this.getAttribute("data-images") || "[]");
        var index = parseInt(this.getAttribute("data-index") || "0", 10);
        if (window.openImageLightbox) {
          window.openImageLightbox(images, index);
        }
      });
    });

    function syncEmptyState() {
      var cards = grid.querySelectorAll("[data-favourite-card]");
      if (!emptyState) return;
      if (cards.length === 0) {
        emptyState.classList.remove("d-none");
        grid.appendChild(emptyState);
      } else {
        emptyState.classList.add("d-none");
      }
    }

    function popFavouriteIcon(icon) {
      icon.classList.remove("fav-pop");
      void icon.offsetWidth;
      icon.classList.add("fav-pop");
      icon.addEventListener("animationend", function () {
        icon.classList.remove("fav-pop");
      }, { once: true });
    }

    document.querySelectorAll(".js-favourite-form").forEach(function (form) {
      form.addEventListener("submit", async function (e) {
        e.preventDefault();
        var btn  = form.querySelector(".js-favourite-btn");
        var icon = form.querySelector(".js-favourite-icon");

        // Optimistic visual: immediately flip the icon to outline + pop
        if (icon) {
          icon.classList.remove("fa-solid", "text-danger");
          icon.classList.add("fa-regular");
          popFavouriteIcon(icon);
        }
        if (btn) btn.disabled = true;

        try {
          var response = await fetch(form.action, {
            method: "POST",
            headers: {
              "X-Requested-With": "XMLHttpRequest",
              Accept: "application/json",
            },
          });
          if (!response.ok) throw new Error("Failed to toggle favourite");
          var data = await response.json();
          if (!data.isFavourite) {
            var listingId = form.getAttribute("data-listing-id");
            var card = grid.querySelector('[data-favourite-card="' + listingId + '"]');
            if (card) {
              card.classList.add("fav-card-removing");
              card.addEventListener("animationend", function () {
                card.remove();
                syncEmptyState();
              }, { once: true });
            }
          } else {
            // Server kept it as favourite — revert the optimistic icon flip
            if (icon) {
              icon.classList.add("fa-solid", "text-danger");
              icon.classList.remove("fa-regular");
            }
            if (btn) btn.disabled = false;
          }
        } catch (err) {
          // Revert optimistic icon change on error
          if (icon) {
            icon.classList.add("fa-solid", "text-danger");
            icon.classList.remove("fa-regular");
          }
          if (btn) btn.disabled = false;
          form.submit();
        }
      });
    });
  })();
</script>
